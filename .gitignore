# Build / packaging artifacts
*.deb
*.buildinfo
*.changes
build/

# debhelper build artifacts (dpkg-buildpackage / make deb) — the tracked
# debian/*.install and debian/pve-fclu-*.install files are NOT matched (no slash).
debian/.debhelper/
debian/tmp/
debian/files
debian/debhelper-build-stamp
debian/*.substvars
debian/pve-fclu-core/
debian/pve-fclu-hitachi/
debian/pve-fclu/

# CLI scratch output (joint-review runs, etc.)
*.err

# Local agent/orchestration tooling state — never commit (may contain lab specifics).
# Root-anchored so committed docs/ is unaffected.
/.claude/
# OMC operational state. Unanchored so a nested docs/.omc/ (created when a tool
# runs with a subdirectory as cwd) is ignored too, not just the repo-root one.
.omc/
/.codex/
/reference/
